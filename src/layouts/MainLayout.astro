---
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/layout.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const site = Astro.site ?? new URL("https://nelsonjhongp.github.io");
const deployedBaseUrl = import.meta.env.BASE_URL === "/" ? "/portafolio/" : import.meta.env.BASE_URL;
const canonicalPath = Astro.url.pathname === "/" ? deployedBaseUrl : Astro.url.pathname;
const canonical = new URL(canonicalPath, site).toString();
const image = new URL(`${deployedBaseUrl}og/portfolio-og.png`, site).toString();
const baseUrl = import.meta.env.BASE_URL;
const favicon = `${baseUrl}brand/nj-icon.png`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1d2129" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={favicon} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Nelson Jhon Gil Pari" />
    <meta property="og:image" content={image} />
    <meta property="og:image:secure_url" content={image} />
    <meta property="og:image:alt" content="Vista previa del portafolio de Nelson Jhon Gil Pari" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content="Vista previa del portafolio de Nelson Jhon Gil Pari" />
    <script is:inline>
      (() => {
        const storageKey = "nejigiku-theme";
        const storedTheme = window.localStorage.getItem(storageKey);
        const theme = storedTheme === "light" || storedTheme === "dark" ? storedTheme : "dark";
        const root = document.documentElement;
        root.dataset.theme = theme;
        const themeColor = theme === "light" ? "#f5f7fb" : "#1d2129";
        const meta = document.querySelector('meta[name="theme-color"]');

        if (meta) {
          meta.setAttribute("content", themeColor);
        }
      })();
    </script>
  </head>
  <body data-app-shell>
    <slot />
  </body>
</html>
