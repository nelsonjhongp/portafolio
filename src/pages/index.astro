---
import "./home.css";
import { asset } from "../utils/assets";
import AboutSection from "../components/about/AboutSection.astro";
import ContactPanel from "../components/contact/ContactPanel.astro";
import EducationSection from "../components/education/EducationSection.astro";
import Hero from "../components/hero/Hero.astro";
import KnowledgeSection from "../components/knowledge/KnowledgeSection.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import BackToTop from "../components/shared/BackToTop.astro";
import Footer from "../components/shared/Footer.astro";
import SiteNavigation from "../components/shared/SiteNavigation.astro";
import SectionHeader from "../components/shared/SectionHeader.astro";
import { profile } from "../content/profile";
import { projects } from "../content/projects";
import MainLayout from "../layouts/MainLayout.astro";

const featuredProjects = projects.filter((project) => project.featured);
---

<MainLayout
  title="Portafolio | Nelson Jhon Gil Pari"
  description="Desarrollador de Software. Construyo aplicaciones web, backend y herramientas de escritorio con React, Next.js, Node.js y PostgreSQL. Estudiante de Ing. de Software."
>
  <div class="page-shell">
    <SiteNavigation
      brandHref="#top"
      brandImage="/brand/nj-logo.png"
      brandAlt="Logo de Nelson Nejigiku"
      links={[
        { href: "#about", label: "Sobre mí" },
        { href: "#stack", label: "Conocimientos" },
        { href: "#projects", label: "Proyectos" },
        { href: "#education", label: "Formación académica" },
        { href: "#contact", label: "Contacto" }
      ]}
    />

    <main>
      <Hero profile={profile} />
      <AboutSection profile={profile} />
      <KnowledgeSection profile={profile} />

      <section class="section section-projects section-muted" id="projects">
        <div class="section-inner">
          <SectionHeader
            fluid={true}
            title="Mis Proyectos"
            icon={asset("/icons/code-icon.svg")}
            variant="framed-left"
            text="Una selección de proyectos que representa mejor mi nivel actual y el tipo de software que me interesa seguir construyendo."
          />

          <div class="projects-grid">
            {featuredProjects.map((project) => <ProjectCard project={project} />)}
          </div>
        </div>
      </section>

      <EducationSection profile={profile} />
      <ContactPanel profile={profile} />
    </main>

    <Footer name={profile.name} />
    <BackToTop />
  </div>
</MainLayout>
