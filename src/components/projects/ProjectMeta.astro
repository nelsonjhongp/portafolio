---
import "./ProjectMeta.css";
import type { Project } from "../../types/portfolio";
import TechChip from "../shared/TechChip.astro";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div class="project-heading">
  <div class="project-header-row">
    {project.eyebrow ? <p class="project-eyebrow">{project.eyebrow}</p> : null}
    <span class="project-status">{project.status}</span>
  </div>
  <h3>{project.name}</h3>
  <p class="project-summary">{project.summary}</p>
</div>

<div class="project-tech-row" aria-label={`Tecnologías usadas en ${project.name}`}>
  {(project.cardStack ?? project.stack).map((item) => <TechChip item={item} variant="project" />)}
</div>
