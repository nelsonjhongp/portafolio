---
import "./ProjectLinks.css";
import type { ProjectLink } from "../../types/portfolio";

interface Props {
  projectName: string;
  links: ProjectLink[];
}

const { projectName, links } = Astro.props;
---

<div class="project-links" aria-label={`Enlaces de ${projectName}`}>
  {links.map((link) => (
    <a
      class:list={[
        "project-link",
        link.kind === "release"
          ? "project-link-release"
          : link.kind === "repo"
            ? "project-link-arrow"
            : "project-link-subtle"
      ]}
      href={link.href}
      target="_blank"
      rel="noreferrer"
    >
      {link.kind === "repo" ? (
        <svg class="project-link-github" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.41-4.04-1.41-.55-1.37-1.33-1.73-1.33-1.73-1.09-.73.08-.72.08-.72 1.2.08 1.84 1.23 1.84 1.23 1.08 1.83 2.82 1.3 3.5.99.11-.77.42-1.3.77-1.6-2.67-.3-5.48-1.31-5.48-5.9 0-1.31.47-2.37 1.23-3.21-.12-.3-.53-1.53.12-3.18 0 0 1.01-.32 3.3 1.23a11.6 11.6 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.65.24 2.88.12 3.18.77.84 1.23 1.9 1.23 3.21 0 4.6-2.82 5.59-5.51 5.88.43.37.82 1.1.82 2.23v3.3c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z"/>
        </svg>
      ) : link.kind === "release" ? (
        <svg class="project-link-release-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 3.5v7m0 0 3-3m-3 3-3-3M4.5 12.5v1a2 2 0 0 0 2 2h7a2 2 0 0 0 2-2v-1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      ) : null}
      {link.label}
      {link.kind === "repo" ? (
        <svg class="link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 10h11.5M10.5 4.5 16 10l-5.5 5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      ) : null}
    </a>
  ))}
</div>
