---
import "./ProjectLinks.css";
import type { ProjectLink } from "../../types/portfolio";
import { asset } from "../../utils/assets";

interface Props {
  projectName: string;
  links: ProjectLink[];
  modalDialogId?: string;
}

const { projectName, links, modalDialogId } = Astro.props;
const arrowIcon = asset("/icons/lucide--arrow-right.svg");
const githubIcon = asset("/icons/tech/github-mark.svg");
const downloadIcon = asset("/icons/lucide--download.svg");
---

<div class="project-links" aria-label={`Enlaces de ${projectName}`}>
  {modalDialogId ? (
    <button
      class="project-link project-link-arrow project-link-button"
      type="button"
      data-project-modal-open={modalDialogId}
      aria-haspopup="dialog"
      aria-controls={modalDialogId}
    >
      Ver caso
      <span class="link-arrow project-link-button__arrow" style={`--icon-url: url('${arrowIcon}')`} aria-hidden="true"></span>
    </button>
  ) : null}

  {links.map((link) => (
    <a
      class:list={[
        "project-link",
        link.kind === "release"
          ? "project-link-release"
          : link.kind === "repo"
            ? "project-link-arrow"
            : "project-link-subtle"
      ]}
      href={link.href}
      target="_blank"
      rel="noreferrer"
    >
      {link.kind === "repo" ? (
        <span class="project-link-github" style={`--icon-url: url('${githubIcon}')`} aria-hidden="true"></span>
      ) : link.kind === "release" ? (
        <span class="project-link-release-icon" style={`--icon-url: url('${downloadIcon}')`} aria-hidden="true"></span>
      ) : null}
      {link.label}
      {link.kind === "repo" ? (
        <span class="link-arrow" style={`--icon-url: url('${arrowIcon}')`} aria-hidden="true"></span>
      ) : null}
    </a>
  ))}
</div>
