---
import "./BackToTop.css";
import { asset } from "../../utils/assets";
---

<button class="back-to-top" type="button" aria-label="Volver arriba">
  <img src={asset("/icons/lucide--arrow-up.svg")} alt="" class="back-to-top__icon" aria-hidden="true" />
</button>

<script>
  const backToTopButton = document.querySelector(".back-to-top");

  if (backToTopButton instanceof HTMLButtonElement) {
    const onScroll = () => {
      backToTopButton.classList.toggle("is-visible", window.scrollY > 420);
    };

    backToTopButton.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
