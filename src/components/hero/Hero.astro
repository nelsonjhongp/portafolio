---
import "./Hero.css";
import type { Profile } from "../../types/portfolio";
import { asset } from "../../utils/assets";
import ActionLink from "../shared/ActionLink.astro";
import TechChip from "../shared/TechChip.astro";

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
const heroPortrait = asset("/brand/nelson-linkedin-profile-hero.png");
const heroBackgroundLight = asset("/brand/portafolio-njgk-hero-background.webp");
const heroBackgroundDark = asset("/brand/portafolio-njgk-hero-background-dark.webp");
const emailIcon = asset("/icons/lucide--mail.svg");
---

<section
  class="hero"
  id="top"
  style={`--hero-background-image-light: url('${heroBackgroundLight}'); --hero-background-image-dark: url('${heroBackgroundDark}')`}
>
  <div class="hero-inner">
    <div class="hero-copy">
      <h1 class="hero-name">
        <span>Nelson Jhon</span>
        <span>Gil Pari</span>
      </h1>

      <div class="hero-portrait-mobile" aria-hidden="true">
        <div class="hero-portrait-mobile-frame">
          <img src={heroPortrait} alt="" loading="eager" />
        </div>
      </div>

      <p class="hero-role">
        <span class="hero-role-accent">Desarrollador de software</span>
        <span class="hero-role-rest"> orientado a datos y procesos reales</span>
      </p>

      <p class="hero-summary">
        {profile.subtitle}
      </p>

      <div class="hero-stack-panel" aria-label="Tecnologías principales">
        <ul class="hero-stack-grid">
          {profile.mainStack.map((item) => (
            <li>
              <TechChip item={item} variant="hero" />
            </li>
          ))}
        </ul>
      </div>

      <div class="hero-actions">
        <div class="hero-actions-primary">
          <ActionLink href="#projects" label="Ver proyectos" kind="projects" hideIcon={true} />
          <ActionLink href={profile.contact.cvEs} label="Ver CV" kind="cv" hideIcon={true} />
        </div>

        <div class="hero-actions-social" aria-label="Enlaces de contacto">
          <a class="hero-social-link" href={profile.contact.github} target="_blank" rel="noreferrer" aria-label="GitHub">
            <img src={asset("/icons/tech/github-icon.svg")} alt="" aria-hidden="true" />
          </a>
          <a class="hero-social-link" href={profile.contact.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn">
            <img src={asset("/icons/tech/linkedin-icon.svg")} alt="" aria-hidden="true" />
          </a>
          <a class="hero-social-link" href={profile.contact.email} aria-label="Correo">
            <img src={emailIcon} alt="" aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>

    <div class="hero-portrait">
      <div class="hero-portrait-frame">
        <img src={heroPortrait} alt="Foto de perfil de Nelson Jhon Gil Pari" loading="eager" />
      </div>
    </div>
  </div>
</section>
