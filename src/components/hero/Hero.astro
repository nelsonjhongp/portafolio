---
import "./Hero.css";
import type { Profile } from "../../types/portfolio";
import ActionLink from "../shared/ActionLink.astro";

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;

const ambientSymbols = [
  { symbol: "</>", x: "8%", y: "16%", drift: "12px", delay: "0s", duration: "9.8s", opacity: "0.16" },
  { symbol: "()", x: "21%", y: "11%", drift: "10px", delay: "1.4s", duration: "10.6s", opacity: "0.12" },
  { symbol: "{}", x: "34%", y: "18%", drift: "14px", delay: "0.6s", duration: "11.4s", opacity: "0.14" },
  { symbol: "//", x: "14%", y: "28%", drift: "11px", delay: "2.2s", duration: "9.2s", opacity: "0.13" },
  { symbol: "[]", x: "42%", y: "29%", drift: "15px", delay: "1.1s", duration: "12.1s", opacity: "0.1" },
  { symbol: "<>", x: "57%", y: "15%", drift: "13px", delay: "0.3s", duration: "10.2s", opacity: "0.11" },
  { symbol: "::", x: "70%", y: "23%", drift: "9px", delay: "2.8s", duration: "8.9s", opacity: "0.15" },
  { symbol: "=>", x: "84%", y: "18%", drift: "12px", delay: "1.9s", duration: "10.8s", opacity: "0.12" },
  { symbol: "</>", x: "10%", y: "52%", drift: "16px", delay: "1.5s", duration: "11.8s", opacity: "0.11" },
  { symbol: "//", x: "26%", y: "46%", drift: "10px", delay: "0.8s", duration: "9.6s", opacity: "0.12" },
  { symbol: "[]", x: "38%", y: "58%", drift: "12px", delay: "2.4s", duration: "10.4s", opacity: "0.15" },
  { symbol: "()", x: "54%", y: "49%", drift: "14px", delay: "0.5s", duration: "12.2s", opacity: "0.1" },
  { symbol: "{}", x: "68%", y: "57%", drift: "11px", delay: "1.7s", duration: "9.4s", opacity: "0.12" },
  { symbol: "<>", x: "81%", y: "45%", drift: "13px", delay: "2.1s", duration: "10.9s", opacity: "0.13" },
  { symbol: "=>", x: "16%", y: "78%", drift: "9px", delay: "0.9s", duration: "8.7s", opacity: "0.1" },
  { symbol: "::", x: "31%", y: "86%", drift: "12px", delay: "2.6s", duration: "10.1s", opacity: "0.13" },
  { symbol: "</>", x: "58%", y: "81%", drift: "15px", delay: "1.2s", duration: "11.1s", opacity: "0.11" },
  { symbol: "[]", x: "77%", y: "84%", drift: "10px", delay: "0.4s", duration: "9.5s", opacity: "0.12" }
];
---

<section class="hero" id="top">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-rain" aria-hidden="true">
    {ambientSymbols.map((item) => (
      <span
        class="hero-rain-glyph"
        style={`--x:${item.x}; --y:${item.y}; --drift:${item.drift}; --delay:${item.delay}; --duration:${item.duration}; --glyph-opacity:${item.opacity};`}
      >
        {item.symbol}
      </span>
    ))}
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-copy">
    <p class="hero-brand">
      <span class="signal-dot hero-brand-dot" aria-hidden="true"></span>
      {profile.name}
    </p>
    <h1>{profile.title}</h1>
    <p class="hero-subtitle">{profile.subtitle}</p>

    <div class="hero-actions">
      <ActionLink href="#projects" label="Ver proyectos" kind="projects" icon="trailing" />
      <ActionLink href={profile.contact.cvEs} label="Ver CV" kind="cv" icon="trailing" />
      <ActionLink href={profile.contact.github} label="GitHub" kind="github" />
      <ActionLink href={profile.contact.linkedin} label="LinkedIn" kind="linkedin" />
    </div>
  </div>
</section>
