---
import "./AboutSection.css";
import type { Profile } from "../../types/portfolio";
import { asset } from "../../utils/assets";
import SectionHeader from "../shared/SectionHeader.astro";

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
---

<section class="section section-about section-light" id="about">
  <div class="section-inner">
    <SectionHeader
      className="about-header"
      fluid={true}
      title={profile.sectionTexts.aboutTitle}
      icon={asset("/icons/lucide--user.svg")}
      variant="framed-left"
      text={profile.aboutText}
    />

    <div class="about-layout-enhanced">
      <div class="about-copy-column">
        <p class="section-lead">{profile.summary}</p>
        <p class="about-copy">{profile.aboutCallout}</p>
      </div>

      <div class="about-workflow" aria-label="Forma de trabajo">
        {profile.workflowSteps.map((step) => (
          <article class="about-workflow-item">
            <span class="about-workflow-index">
              <img src={step.icon} alt="" aria-hidden="true" />
            </span>
            <div class="about-workflow-copy">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
